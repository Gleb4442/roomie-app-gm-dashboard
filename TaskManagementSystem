## 3. Модели данных

### 3.1. Task (Задача)

```prisma
model Task {
  id              String        @id @default(uuid())
  hotelId         String
  hotel           Hotel         @relation(fields: [hotelId], references: [id])

  // Источник
  guestId         String?       // null если создана персоналом
  guest           Guest?        @relation(fields: [guestId], references: [id])
  roomNumber      String
  source          TaskSource    // CHAT, VOICE, BUTTON, STAFF, EXTERNAL

  // Категория и детали
  categoryId      String
  category        TaskCategory  @relation(fields: [categoryId], references: [id])
  departmentId    String
  department      Department    @relation(fields: [departmentId], references: [id])
  title           String        // Человекочитаемое описание: "Полотенца × 2 (банные)"
  details         Json          // Структурированные данные запроса
  // Пример details для towels: { type: "bath", quantity: 2 }
  // Пример details для cleaning: { type: "full", preferredTime: "14:00" }
  // Пример details для minibar: { items: [{ posId: "...", name: "Evian", qty: 2, price: 150 }] }
  // Пример details для late_checkout: { requestedTime: "16:00", approvedTime: "14:00", cost: 500 }

  // Статус
  status          TaskStatus    @default(CREATED)
  priority        TaskPriority  @default(NORMAL)

  // Назначение
  assigneeId      String?       // Конкретный сотрудник
  assignee        Staff?        @relation("assigned", fields: [assigneeId], references: [id])
  assigneeGroupId String?       // Или группа (первый свободный берёт)
  assigneeGroup   StaffGroup?   @relation(fields: [assigneeGroupId], references: [id])

  // Временные метки
  createdAt       DateTime      @default(now())
  assignedAt      DateTime?
  acceptedAt      DateTime?
  startedAt       DateTime?     // in_progress
  completedAt     DateTime?
  cancelledAt     DateTime?
  estimatedAt     DateTime?     // расчётное время завершения

  // ETA
  etaMinutes      Int?          // текущий ETA в минутах
  etaUpdatedAt    DateTime?

  // SLA
  slaDeadline     DateTime?     // когда SLA будет нарушен
  slaBreached     Boolean       @default(false)
  escalationLevel Int           @default(0) // 0 = нет, 1 = супервайзор, 2 = менеджер, 3 = GM

  // Финансы
  isBillable      Boolean       @default(false)
  cost            Decimal?      @db.Decimal(10, 2)
  currency        String?       @default("UAH")
  billedToRoom    Boolean       @default(false)

  // Внешняя TMS
  externalTmsId   String?       // ID задачи во внешней системе
  externalTmsType String?       // "hotelkit", "flexkeeping", "hotsos"
  syncStatus      SyncStatus    @default(NOT_SYNCED) // NOT_SYNCED, SYNCED, SYNC_ERROR, LOCAL_ONLY

  // Оценка
  rating          Int?          // 1-5
  ratingComment   String?
  ratedAt         DateTime?

  // Связи
  notes           TaskNote[]
  statusHistory   TaskStatusChange[]
  photos          TaskPhoto[]
  chatMessageId   String?       // ID сообщения в чате, из которого создана задача

  @@index([hotelId, status])
  @@index([hotelId, departmentId, status])
  @@index([assigneeId, status])
  @@index([guestId])
  @@index([externalTmsId])
}

enum TaskStatus {
  CREATED         // Задача создана, ожидает назначения
  ASSIGNED        // Назначена сотруднику/группе
  ACCEPTED        // Сотрудник принял
  IN_PROGRESS     // Сотрудник начал выполнение
  COMPLETED       // Выполнена
  CANCELLED       // Отменена (гостем или персоналом)
  ON_HOLD         // На паузе (ожидание гостя, материалов и т.д.)
  ESCALATED       // Эскалирована (SLA нарушен или ручная эскалация)
}

enum TaskPriority {
  LOW             // Может подождать
  NORMAL          // Стандартный
  HIGH            // Приоритетный (VIP гость, повторный запрос)
  URGENT          // Срочный (гость отметил как срочное, или авария)
}

enum TaskSource {
  CHAT            // Текстовое сообщение в чате
  VOICE           // Голосовое сообщение
  BUTTON          // Кнопка в интерфейсе приложения
  STAFF           // Создана персоналом
  EXTERNAL        // Пришла из внешней TMS
}

enum SyncStatus {
  NOT_SYNCED      // Нет внешней TMS или ещё не отправлено
  SYNCED          // Успешно синхронизировано
  SYNC_ERROR      // Ошибка синхронизации
  LOCAL_ONLY      // Только в нашей системе (внешняя TMS не поддерживает)
}
```

### 3.2. TaskCategory (Категория сервиса)

```prisma
model TaskCategory {
  id              String    @id @default(uuid())
  hotelId         String
  hotel           Hotel     @relation(fields: [hotelId], references: [id])

  slug            String    // "room_cleaning", "towels_amenities", "minibar_restock", "late_checkout", custom...
  isDefault       Boolean   @default(false) // true для 4 дефолтных
  isActive        Boolean   @default(true)

  // Мультиязычные названия
  names           Json      // { "en": "Room Cleaning", "uk": "Прибирання кімнати", "ru": "Уборка номера" }
  descriptions    Json?     // { "en": "Full room cleaning service", ... }
  icon            String    // emoji или название иконки: "bed", "towel", "minibar", "clock"

  // Маршрутизация
  defaultDepartmentId  String
  defaultDepartment    Department @relation(fields: [defaultDepartmentId], references: [id])

  // SLA настройки
  defaultEtaMinutes    Int       @default(30)
  slaMinutes           Int       @default(60) // максимальное время выполнения
  slaWarningMinutes    Int       @default(45) // когда отправить предупреждение

  // Финансы
  defaultIsBillable    Boolean   @default(false)
  defaultPrice         Decimal?  @db.Decimal(10, 2)
  pricingRules         Json?     // Правила ценообразования (зависит от времени, типа номера и т.д.)

  // Доступность
  availableFrom        String?   // "07:00" — с какого времени доступна
  availableTo          String?   // "23:00" — до какого времени
  availableDays        Int[]     // [1,2,3,4,5,6,7] — дни недели (1=Пн)

  // Уточняющие вопросы (для NLU / chat flow)
  clarificationRules   Json?
  // Пример:
  // {
  //   "towels_amenities": {
  //     "fields": [
  //       { "key": "type", "required": false, "default": "bath",
  //         "options": ["bath", "hand", "beach"],
  //         "prompt": { "en": "What type of towels?", "uk": "Які рушники?" },
  //         "quickReplies": { "en": ["Bath", "Hand", "Beach"], "uk": ["Банні", "Для рук", "Пляжні"] }
  //       },
  //       { "key": "quantity", "required": false, "default": 2,
  //         "prompt": { "en": "How many?", "uk": "Скільки?" },
  //         "quickReplies": ["1", "2", "3", "Set"]
  //       }
  //     ]
  //   }
  // }

  // Внешняя TMS
  externalMappings     Json?     // Маппинг на категории внешней TMS
  // { "hotelkit": { "categoryId": "abc123", "subcategoryId": "def456" } }

  tasks           Task[]

  @@unique([hotelId, slug])
}
```

### 3.3. TaskStatusChange (История изменений статуса)

```prisma
model TaskStatusChange {
  id          String      @id @default(uuid())
  taskId      String
  task        Task        @relation(fields: [taskId], references: [id])

  fromStatus  TaskStatus?
  toStatus    TaskStatus
  changedById String?     // staffId или "system"
  changedBy   Staff?      @relation(fields: [changedById], references: [id])
  reason      String?     // Причина (для отмены, эскалации, переназначения)
  timestamp   DateTime    @default(now())

  // Для синхронизации
  syncedToExternal  Boolean @default(false)

  @@index([taskId])
}
```


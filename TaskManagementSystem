### 9.4. GenericWebhookAdapter

Для TMS, у которых нет полноценного API, но есть возможность отправлять/получать вебхуки:

```typescript
class GenericWebhookAdapter implements ITMSAdapter {
  readonly name = 'generic_webhook';

  getCapabilities(): TMSCapabilities {
    return {
      supportedStatuses: ['open', 'closed'],  // Минимум
      hasAcceptedStatus: false,
      hasInProgressStatus: false,
      hasOnHoldStatus: false,
      supportsAssignment: false,
      supportsGroupAssignment: false,
      supportsReassignment: false,
      supportsEscalation: false,
      supportsPriority: false,
      supportsNotes: false,
      supportsPhotos: false,
      supportsETA: false,
      supportsRating: false,
      supportsBilling: false,
      supportsCustomFields: false,
      supportsWebhooks: true,   // Единственная сильная сторона
      supportsPolling: false,
    };
  }

  // Этот адаптер покрывает минимальный сценарий:
  // 1. Создаём задачу → отправляем webhook во внешнюю систему
  // 2. Получаем webhook обратно когда задача закрыта
  // Всё остальное (назначение, статусы, ETA) — эмулируется locally

  async createTask(payload: TaskCreatePayload): Promise<TMSTaskResult> {
    const webhookUrl = this.config.outgoingWebhookUrl;

    const response = await fetch(webhookUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Signature': this.signPayload(payload),
      },
      body: JSON.stringify({
        event: 'task.created',
        task: {
          title: payload.title,
          room: payload.roomNumber,
          category: payload.categorySlug,
          description: payload.description,
          priority: payload.priority,
          timestamp: new Date().toISOString(),
        },
      }),
    });

    return {
      success: response.ok,
      externalId: response.ok ? (await response.json()).id : null,
    };
  }
}

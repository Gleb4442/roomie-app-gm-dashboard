## 17. ETA-калькулятор

```typescript
class ETACalculator {
  /**
   * Рассчитывает ETA для задачи.
   * Возвращает количество минут до завершения.
   */
  async estimate(
    categoryId: string,
    hotelId: string,
    options?: {
      priority?: TaskPriority;
      floor?: number;
      currentTime?: Date;
    }
  ): Promise<number> {
    const category = await TaskCategory.findById(categoryId);

    // 1. Базовое время (из настроек категории)
    let eta = category.defaultEtaMinutes;

    // 2. Историческое среднее (если есть данные за последние 30 дней)
    const historicalAvg = await this.getHistoricalAvg(categoryId, hotelId, 30);
    if (historicalAvg) {
      eta = Math.max(eta, historicalAvg); // Используем большее из двух
    }

    // 3. Коэффициент загрузки
    const currentLoad = await this.getCurrentDepartmentLoad(category.defaultDepartmentId);
    const normalLoad = await this.getNormalLoad(category.defaultDepartmentId);
    const loadFactor = Math.max(1, currentLoad / normalLoad);
    eta *= loadFactor;

    // 4. Коэффициент времени суток
    const hour = (options?.currentTime || new Date()).getHours();
    if (hour >= 23 || hour < 7) {
      eta *= 2; // Ночью — удвоенное время
    } else if (hour >= 10 && hour <= 12) {
      eta *= 1.3; // Час пик checkout — +30%
    }

    // 5. Коэффициент приоритета
    if (options?.priority === 'URGENT') {
      eta *= 0.5; // Срочные — ускоряем ожидание
    }

    // 6. Округление
    eta = Math.ceil(eta / 5) * 5; // Округляем до 5 минут

    return eta;
  }

  /**
   * Пересчёт ETA при изменении статуса.
   */
  async recalculate(task: Task): Promise<number> {
    let remainingEta: number;

    switch (task.status) {
      case 'CREATED':
      case 'ASSIGNED':
        // Ещё не начата — полный ETA
        remainingEta = await this.estimate(task.categoryId, task.hotelId);
        break;

      case 'ACCEPTED':
        // Принята, но не начата — предположительно скоро начнут
        remainingEta = (await this.estimate(task.categoryId, task.hotelId)) * 0.7;
        break;

      case 'IN_PROGRESS':
        // В процессе — рассчитываем оставшееся время
        const elapsed = this.minutesSince(task.startedAt!);
        const totalEstimate = await this.estimate(task.categoryId, task.hotelId);
        remainingEta = Math.max(5, totalEstimate - elapsed);
        break;

      case 'ON_HOLD':
        // На паузе — неопределённо, но даём оценку
        remainingEta = await this.estimate(task.categoryId, task.hotelId);
        break;

      default:
        remainingEta = 0;
    }

    // Обновить в БД и отправить гостю
    await prisma.task.update({
      where: { id: task.id },
      data: { etaMinutes: remainingEta, etaUpdatedAt: new Date() },
    });

    await TaskEventBus.emit(TaskEvent.TASK_ETA_UPDATED, { ...task, etaMinutes: remainingEta });

    return remainingEta;
  }
}
```


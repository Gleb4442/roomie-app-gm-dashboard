### 9.2. Пример: HotelkitAdapter

```typescript
class HotelkitAdapter implements ITMSAdapter {
  readonly name = 'hotelkit';
  readonly version = '2.0';

  private apiClient: HotelkitAPIClient;
  private config: HotelkitConfig;

  constructor(config: HotelkitConfig) {
    this.config = config;
    this.apiClient = new HotelkitAPIClient({
      baseUrl: config.apiUrl,
      apiKey: config.apiKey,
      hotelCode: config.hotelCode,
    });
  }

  getCapabilities(): TMSCapabilities {
    return {
      supportedStatuses: ['open', 'acknowledged', 'in_progress', 'on_hold', 'done', 'cancelled'],
      hasAcceptedStatus: true,    // "acknowledged"
      hasInProgressStatus: true,  // "in_progress"
      hasOnHoldStatus: true,      // "on_hold"
      supportsAssignment: true,
      supportsGroupAssignment: true,
      supportsReassignment: true,
      supportsEscalation: true,
      supportsPriority: true,
      supportsNotes: true,
      supportsPhotos: true,
      supportsETA: false,         // Hotelkit не возвращает ETA
      supportsRating: false,
      supportsBilling: false,
      supportsCustomFields: true,
      supportsWebhooks: true,
      supportsPolling: true,
      pollingIntervalMs: 60000,
      maxTitleLength: 255,
      maxNoteLength: 2000,
      maxPhotosPerTask: 10,
      rateLimitPerMinute: 60,
    };
  }

  // Status mapping: наш → Hotelkit
  mapStatus(internalStatus: TaskStatus): string | null {
    const map: Record<TaskStatus, string | null> = {
      CREATED: 'open',
      ASSIGNED: 'open',        // Hotelkit не различает created/assigned
      ACCEPTED: 'acknowledged',
      IN_PROGRESS: 'in_progress',
      ON_HOLD: 'on_hold',
      COMPLETED: 'done',
      CANCELLED: 'cancelled',
      ESCALATED: null,          // Hotelkit имеет свою эскалацию
    };
    return map[internalStatus];
  }

  // Status mapping: Hotelkit → наш
  mapStatusReverse(externalStatus: string): TaskStatus | null {
    const map: Record<string, TaskStatus> = {
      'open': 'CREATED',
      'acknowledged': 'ACCEPTED',
      'in_progress': 'IN_PROGRESS',
      'on_hold': 'ON_HOLD',
      'done': 'COMPLETED',
      'cancelled': 'CANCELLED',
    };
    return map[externalStatus] || null;
  }

  mapPriority(internal: TaskPriority): string | null {
    // Hotelkit: 3 уровня → маппим наши 4 на их 3
    const map: Record<TaskPriority, string> = {
      LOW: 'low',
      NORMAL: 'normal',
      HIGH: 'high',
      URGENT: 'high', // Нет "urgent" в Hotelkit
    };
    return map[internal];
  }

  async createTask(payload: TaskCreatePayload): Promise<TMSTaskResult> {
    const response = await this.apiClient.post('/tasks', {
      title: payload.title.substring(0, 255),
      description: payload.description,
      category_id: payload.category,
      department_id: payload.department,
      room: payload.roomNumber,
      priority: payload.priority,
      assignee_id: payload.assigneeExternalId,
      custom_fields: payload.customFields,
    });

    return {
      success: true,
      externalId: response.data.id,
      externalStatus: response.data.status,
    };
  }

  async updateTaskStatus(externalId: string, status: string): Promise<TMSTaskResult> {
    const response = await this.apiClient.patch(`/tasks/${externalId}`, {
      status,
    });

    return {
      success: true,
      externalId,
      externalStatus: response.data.status,
    };
  }

  // Webhook handler
  async handleWebhook(payload: HotelkitWebhookPayload): Promise<void> {
    switch (payload.event) {
      case 'task.status_changed':
        await TMSAdapterManager.syncStatusFromExternal(
          this.config.hotelId,
          payload.task_id,
          payload.new_status
        );
        break;
      case 'task.assigned':
        await TMSAdapterManager.syncAssignmentFromExternal(
          this.config.hotelId,
          payload.task_id,
          payload.assignee_id
        );
        break;
      case 'task.note_added':
        await TMSAdapterManager.syncNoteFromExternal(
          this.config.hotelId,
          payload.task_id,
          payload.note
        );
        break;
    }
  }
}
```


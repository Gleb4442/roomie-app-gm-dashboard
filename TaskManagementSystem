## 10. Chat Flow и NLU-обработка

### 10.1. NLU Pipeline

```typescript
class NLUPipeline {
  /**
   * Вход: текст или транскрипция голосового сообщения
   * Выход: структурированный интент с entities
   */
  async parse(input: string, context: GuestContext): Promise<NLUResult> {
    // 1. Language detection
    const language = await this.detectLanguage(input);

    // 2. Intent classification
    //    Используем GPT с system prompt, содержащим список категорий отеля
    const intentResult = await this.classifyIntent(input, context, language);

    // 3. Entity extraction
    //    Количество, тип, время, номер комнаты (если отличается от контекста)
    const entities = await this.extractEntities(input, intentResult.category, language);

    // 4. Проверка достаточности данных
    const missingFields = this.checkRequiredFields(
      intentResult.category,
      entities,
      context
    );

    return {
      language,
      intent: intentResult.intent,       // "request_service", "check_status", "cancel_order", "general_question"
      category: intentResult.category,   // "towels_amenities", "room_cleaning", etc. или null
      entities,                          // { type: "bath", quantity: 2, preferredTime: "14:00" }
      confidence: intentResult.confidence,
      missingFields,                     // ["quantity"] — что нужно уточнить
      suggestedDefaults: this.getSuggestedDefaults(intentResult.category, entities, context),
    };
  }
}

interface GuestContext {
  guestId: string;
  guestName: string;
  roomNumber: string;
  hotelId: string;
  language: string;
  checkIn: Date;
  checkOut: Date;
  isVip: boolean;
  previousRequests: Task[];        // История запросов (для умных дефолтов)
  currentActiveOrders: Task[];     // Активные заказы (для "где мои полотенца?")
  hotelCategories: TaskCategory[]; // Доступные категории этого отеля
}

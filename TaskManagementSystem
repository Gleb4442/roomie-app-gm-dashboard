## 6. Маршрутизация и назначение задач

### 6.1. TaskRouter — алгоритм маршрутизации

```typescript
class TaskRouter {
  /**
   * Основной метод маршрутизации.
   * Вызывается сразу после создания задачи.
   */
  async route(task: Task): Promise<RoutingResult> {
    // 1. Определить режим TMS
    const tmsMode = await this.getTMSMode(task.hotelId);

    if (tmsMode === 'external') {
      // Внешняя TMS — отправляем через адаптер
      return this.routeToExternalTMS(task);
    }

    // 2. Built-in TMS — полная маршрутизация
    return this.routeBuiltIn(task);
  }

  private async routeBuiltIn(task: Task): Promise<RoutingResult> {
    // Шаг 1: Определить департамент (из категории или переопределения)
    const department = await this.resolveDepartment(task);

    // Шаг 2: Найти подходящую группу сотрудников
    const group = await this.resolveGroup(task, department);

    // Шаг 3: Найти конкретного исполнителя
    const assignee = await this.resolveAssignee(task, department, group);

    if (assignee) {
      // Назначить конкретному сотруднику
      return { type: 'direct', assigneeId: assignee.id };
    } else if (group) {
      // Назначить группе (первый свободный берёт)
      return { type: 'group', groupId: group.id };
    } else {
      // Никого нет — эскалация
      return { type: 'escalate', reason: 'no_available_staff' };
    }
  }
}
```

### 6.2. AssignmentService — выбор конкретного исполнителя

```typescript
class AssignmentService {
  /**
   * Трёхуровневый алгоритм выбора исполнителя:
   * Level 1: Rule-based фильтрация
   * Level 2: Scoring (опционально)
   * Level 3: Fallback
   */
  async findBestAssignee(
    task: Task,
    department: Department,
    group?: StaffGroup
  ): Promise<Staff | null> {

    // ═══ LEVEL 1: Rule-based фильтрация ═══

    let candidates = await this.getAvailableStaff(department.id);

    // 1a. Фильтр по смене: кто сейчас на работе?
    candidates = candidates.filter(s => this.isOnShift(s));

    // 1b. Фильтр по этажу/зоне: кто обслуживает нужный этаж?
    const floor = this.extractFloor(task.roomNumber);
    const floorStaff = candidates.filter(s => this.servesFloor(s, floor));
    if (floorStaff.length > 0) {
      candidates = floorStaff; // Предпочитаем сотрудников этажа
    }

    // 1c. Фильтр по загрузке: кто не перегружен?
    candidates = candidates.filter(s =>
      this.getCurrentLoad(s) < this.getMaxLoad(s)
    );

    // 1d. Фильтр по навыкам (если категория требует)
    if (task.category.requiredSkills?.length) {
      candidates = candidates.filter(s =>
        task.category.requiredSkills.every(skill => s.skills.includes(skill))
      );
    }

    if (candidates.length === 0) return null;
    if (candidates.length === 1) return candidates[0];

    // ═══ LEVEL 2: Scoring (AI-assisted, опционально) ═══

    const scored = candidates.map(staff => ({
      staff,
      score: this.calculateScore(staff, task),
    }));

    scored.sort((a, b) => b.score - a.score);

    return scored[0].staff;
  }

  /**
   * Скоринг кандидата. Возвращает число 0–100.
   */
  private calculateScore(staff: Staff, task: Task): number {
    let score = 50; // Базовый

    // Текущая загрузка (меньше = лучше)
    const loadRatio = this.getCurrentLoad(staff) / this.getMaxLoad(staff);
    score += (1 - loadRatio) * 20; // до +20

    // Среднее время выполнения аналогичных задач (быстрее = лучше)
    const avgTime = this.getAvgCompletionTime(staff, task.categoryId);
    const categoryAvg = task.category.defaultEtaMinutes;
    if (avgTime && avgTime < categoryAvg) {
      score += 15; // Быстрее среднего
    }

    // Рейтинг качества (выше = лучше)
    const qualityRating = this.getQualityRating(staff);
    score += (qualityRating / 5) * 15; // до +15

    // VIP-бонус: если гость VIP и сотрудник имеет VIP-навык
    if (task.guest?.isVip && staff.skills.includes('vip_service')) {
      score += 10;
    }

    // Proximity: если известна текущая позиция сотрудника
    const distance = this.estimateDistance(staff.currentFloor, this.extractFloor(task.roomNumber));
    score -= distance * 2; // Штраф за расстояние

    return Math.max(0, Math.min(100, score));
  }
}
```

### 6.3. Режим "Group Assignment" (Первый свободный)

Когда конкретного исполнителя выбрать невозможно (все примерно равны или настройка отеля предпочитает "pull"-модель):

```typescript
// Задача назначается группе, а не конкретному сотруднику
// Все члены группы получают push-уведомление
// Первый, кто нажал "Принять" — становится исполнителем
// Остальные видят, что задача уже взята

async function assignToGroup(task: Task, group: StaffGroup): Promise<void> {
  task.assigneeGroupId = group.id;
  task.assigneeId = null;
  task.status = TaskStatus.ASSIGNED;

  // Уведомить всех членов группы
  const members = await getActiveGroupMembers(group.id);
  await Promise.all(
    members.map(member =>
      NotificationService.push(member.id, {
        title: `Новый запрос: ${task.title}`,
        body: `Номер ${task.roomNumber} • ${task.category.name}`,
        data: { taskId: task.id, action: 'accept_task' },
      })
    )
  );
}

// Когда сотрудник принимает задачу из группового назначения
async function acceptGroupTask(taskId: string, staffId: string): Promise<void> {
  // Атомарная операция — предотвращаем race condition
  const updated = await prisma.task.updateMany({
    where: {
      id: taskId,
      status: TaskStatus.ASSIGNED,
      assigneeId: null, // Ещё никто не взял
    },
    data: {
      assigneeId: staffId,
      status: TaskStatus.ACCEPTED,
      acceptedAt: new Date(),
    },
  });

  if (updated.count === 0) {
    throw new TaskAlreadyAcceptedError();
  }

  // Уведомить остальных членов группы, что задача взята
  await NotificationService.dismissForGroup(taskId);
}

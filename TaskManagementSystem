### 12.2. Действия сотрудника с задачей

```typescript
// Все доступные действия определяются ролью + текущим статусом задачи

function getAvailableActions(task: Task, staff: Staff): StaffAction[] {
  const actions: StaffAction[] = [];
  const role = staff.role;

  switch (task.status) {
    case 'ASSIGNED':
      if (task.assigneeId === staff.id || task.assigneeGroupId && staff.groups.includes(task.assigneeGroupId)) {
        actions.push('accept', 'decline');
      }
      if (['supervisor', 'shift_manager', 'duty_manager', 'gm'].includes(role)) {
        actions.push('reassign', 'change_priority', 'cancel');
      }
      break;

    case 'ACCEPTED':
      if (task.assigneeId === staff.id) {
        actions.push('start', 'add_note', 'add_photo');
      }
      if (['supervisor', 'shift_manager'].includes(role)) {
        actions.push('reassign');
      }
      break;

    case 'IN_PROGRESS':
      if (task.assigneeId === staff.id) {
        actions.push('complete', 'hold', 'add_note', 'add_photo', 'escalate');
      }
      if (['supervisor', 'shift_manager'].includes(role)) {
        actions.push('reassign', 'change_priority');
      }
      break;

    case 'ON_HOLD':
      if (task.assigneeId === staff.id) {
        actions.push('resume', 'escalate', 'add_note');
      }
      break;

    case 'ESCALATED':
      if (['supervisor', 'shift_manager', 'duty_manager', 'gm'].includes(role)) {
        actions.push('reassign', 'accept', 'cancel', 'change_priority');
      }
      break;
  }

  return actions;
}
```


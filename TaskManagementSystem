### 10.2. Dialog Manager

```typescript
class DialogManager {
  /**
   * Управляет conversation flow:
   * - Если данных достаточно → подтверждение
   * - Если данных не хватает → уточняющий вопрос
   * - Если интент не сервисный → обычный ответ AI
   */
  async handleMessage(
    message: string,
    context: GuestContext,
    dialogState: DialogState
  ): Promise<ChatResponse> {

    // Если идёт активный диалог (ждём ответ на уточняющий вопрос)
    if (dialogState.awaitingClarification) {
      return this.handleClarificationResponse(message, context, dialogState);
    }

    // Новый запрос
    const nluResult = await NLUPipeline.parse(message, context);

    // Не сервисный интент — обычный AI ответ
    if (nluResult.intent !== 'request_service') {
      return this.handleNonServiceIntent(nluResult, context);
    }

    // Сервисный интент
    if (nluResult.missingFields.length === 0) {
      // Все данные есть → предложить подтверждение
      return this.proposeConfirmation(nluResult, context);
    } else {
      // Нужны уточнения → задать вопрос
      return this.askClarification(nluResult, context);
    }
  }

  /**
   * Формирование уточняющего вопроса.
   * Принцип: один вопрос за раз, с quick-reply кнопками.
   */
  private async askClarification(
    nluResult: NLUResult,
    context: GuestContext
  ): Promise<ChatResponse> {
    const field = nluResult.missingFields[0]; // Первое недостающее поле
    const category = await TaskCategory.findBySlug(nluResult.category, context.hotelId);
    const rules = category.clarificationRules;
    const fieldConfig = rules.fields.find(f => f.key === field);

    return {
      type: 'clarification',
      text: fieldConfig.prompt[context.language],
      quickReplies: fieldConfig.quickReplies[context.language] || fieldConfig.quickReplies,
      dialogState: {
        awaitingClarification: true,
        category: nluResult.category,
        collectedEntities: nluResult.entities,
        missingFields: nluResult.missingFields,
        currentField: field,
      },
    };
  }

  /**
   * Предложение подтверждения с умными дефолтами.
   */
  private async proposeConfirmation(
    nluResult: NLUResult,
    context: GuestContext
  ): Promise<ChatResponse> {
    const details = { ...nluResult.suggestedDefaults, ...nluResult.entities };
    const category = await TaskCategory.findBySlug(nluResult.category, context.hotelId);

    // Проверить доступность
    const availability = await this.checkAvailability(category, context);
    if (!availability.available) {
      return this.handleUnavailable(availability, category, context);
    }

    // Проверить стоимость
    const pricing = await this.calculatePricing(category, details, context);

    // Рассчитать ETA
    const eta = await ETACalculator.estimate(category, context.hotelId);

    // Сформировать текст подтверждения
    const confirmationText = this.buildConfirmationText(
      category, details, eta, pricing, context.language
    );

    return {
      type: 'confirmation',
      text: confirmationText,
      quickReplies: pricing.cost > 0
        ? [
            { label: `Да, ${pricing.formattedCost} → счёт номера`, value: 'confirm_paid' },
            { label: 'Нет, отмена', value: 'cancel' },
          ]
        : [
            { label: 'Да ✓', value: 'confirm' },
            { label: 'Изменить', value: 'modify' },
          ],
      dialogState: {
        awaitingConfirmation: true,
        category: nluResult.category,
        collectedEntities: details,
        eta,
        pricing,
      },
    };
  }

  /**
   * Обработка подтверждения → создание задачи.
   */
  private async handleConfirmation(
    context: GuestContext,
    dialogState: DialogState
  ): Promise<ChatResponse> {
    // Создать задачу
    const task = await TaskService.create({
      hotelId: context.hotelId,
      guestId: context.guestId,
      roomNumber: context.roomNumber,
      categorySlug: dialogState.category,
      details: dialogState.collectedEntities,
      priority: context.isVip ? 'HIGH' : 'NORMAL',
      source: 'CHAT',
      isBillable: dialogState.pricing?.cost > 0,
      cost: dialogState.pricing?.cost,
    });

    return {
      type: 'task_created',
      text: null, // Текст не нужен — показываем карточку
      taskCard: {
        taskId: task.id,
        title: task.title,
        icon: task.category.icon,
        roomNumber: task.roomNumber,
        etaMinutes: task.etaMinutes,
        status: task.status,
        cost: task.isBillable ? task.cost : null,
        ordersDeepLink: `roomie://orders/${task.id}`,
      },
      quickReplies: [],
      dialogState: { idle: true },
    };
  }
}

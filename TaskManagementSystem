### 3.7. StaffGroup (Группа сотрудников)

```prisma
model StaffGroup {
  id          String    @id @default(uuid())
  hotelId     String
  hotel       Hotel     @relation(fields: [hotelId], references: [id])

  name        String    // "3rd Floor Housekeeping", "Night Shift Front Desk"
  type        GroupType // FLOOR, SHIFT, SKILL, CUSTOM

  departmentId String
  department  Department @relation(fields: [departmentId], references: [id])

  // Критерии группы
  floors      Int[]     // [3, 4] — этажи, которые обслуживает группа
  shiftStart  String?   // "07:00"
  shiftEnd    String?   // "15:00"
  skills      String[]  // ["deep_cleaning", "vip_service"]

  members     Staff[]   @relation("groupMembers")
  tasks       Task[]

  @@index([hotelId, departmentId])
}

enum GroupType {
  FLOOR       // Группа по этажам
  SHIFT       // Группа по сменам
  SKILL       // Группа по навыкам
  CUSTOM      // Произвольная группа
}
```


  await TaskNote.create({
    taskId,
    authorId: staffId,
    authorType: 'staff',
    content: `Отклонено: ${reason}`,
    isInternal: true,
  });

  // Исключить этого сотрудника из кандидатов и переназначить
  const newAssignee = await AssignmentService.findBestAssignee(task, {
    excludeStaffIds: [staffId],
  });

  if (newAssignee) {
    await reassignTask(task, newAssignee);
  } else {
    await escalateTask(task, 'no_available_staff_after_decline');
  }
}

// 2. Сотрудник завершил смену с незакрытыми задачами
async function handleShiftEnd(staffId: string): Promise<void> {
  const openTasks = await prisma.task.findMany({
    where: {
      assigneeId: staffId,
      status: { in: ['ASSIGNED', 'ACCEPTED', 'IN_PROGRESS'] },
    },
  });

  for (const task of openTasks) {
    if (task.status === 'IN_PROGRESS') {
      // В процессе — уведомить супервайзора для решения
      await escalateTask(task, 'assignee_shift_ended_during_execution');

### 2.3. Шина событий (TaskEventBus)

Все изменения задач проходят через внутреннюю шину событий. Это единая точка, к которой подписываются все заинтересованные сервисы.

```typescript
// Типы событий
enum TaskEvent {
  TASK_CREATED       = 'task.created',
  TASK_ASSIGNED      = 'task.assigned',
  TASK_ACCEPTED      = 'task.accepted',
  TASK_IN_PROGRESS   = 'task.in_progress',
  TASK_COMPLETED     = 'task.completed',
  TASK_CANCELLED     = 'task.cancelled',
  TASK_ESCALATED     = 'task.escalated',
  TASK_REASSIGNED    = 'task.reassigned',
  TASK_RATED         = 'task.rated',
  TASK_ETA_UPDATED   = 'task.eta_updated',
  TASK_NOTE_ADDED    = 'task.note_added',
  TASK_SLA_WARNING   = 'task.sla_warning',
  TASK_SLA_BREACHED  = 'task.sla_breached',
}

// Подписчики
TaskEventBus.on(TaskEvent.TASK_CREATED, [
  NotificationService.notifyStaff,       // push сотруднику
  SSEService.broadcastToGuest,           // обновление в чате гостя
  SSEService.broadcastToDashboard,       // обновление дашборда
  SLAMonitor.startTracking,              // запуск таймера SLA
  TMSAdapterManager.syncToExternal,      // синхронизация с внешней TMS (если подключена)
]);

TaskEventBus.on(TaskEvent.TASK_COMPLETED, [
  NotificationService.notifyGuest,       // push гостю
  SSEService.broadcastToGuest,           // обновление в чате
  SSEService.broadcastToDashboard,       // обновление дашборда
  SLAMonitor.stopTracking,              // остановка таймера
  RatingService.scheduleRatingRequest,   // запрос оценки через 2-5 мин
  TMSAdapterManager.syncToExternal,      // синхронизация
  AnalyticsService.recordCompletion,     // запись метрик
]);
```


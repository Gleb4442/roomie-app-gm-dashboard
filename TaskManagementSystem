// Стадии прогресс-бара зависят от категории и текущего статуса

function getProgressStages(task: Task): ProgressStage[] {
  // Дефолтные стадии для большинства категорий
  const stages = [
    {
      label: t('progress.accepted', task.guest.language),  // "Принят"
      matchStatuses: ['CREATED', 'ASSIGNED', 'ACCEPTED'],
      icon: '✓',
    },
    {
      label: t('progress.in_progress', task.guest.language), // "В пути" / "Выполняется"
      matchStatuses: ['IN_PROGRESS'],
      icon: '🚶',
    },
    {
      label: t('progress.completed', task.guest.language),   // "Готово"
      matchStatuses: ['COMPLETED'],
      icon: '✅',
    },
  ];

  // Определить текущую позицию
  return stages.map((stage, index) => ({
    ...stage,
    status: stage.matchStatuses.includes(task.status)
      ? 'current'
      : index < getCurrentStageIndex(task.status, stages)
        ? 'done'
        : 'pending',
    timestamp: getTimestampForStage(task, stage),
  }));
}

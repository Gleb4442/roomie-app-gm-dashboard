### 7.2. Автоэскалация по SLA

```typescript
class SLAMonitor {
  /**
   * Запускается при создании задачи.
   * Планирует серию проверок.
   */
  async startTracking(task: Task): Promise<void> {
    const sla = await this.getSLAConfig(task.categoryId, task.hotelId);

    // Уровень 0: Не принята > sla.acceptanceTimeout (default: 5 мин)
    await this.scheduleCheck(task.id, 'acceptance', sla.acceptanceTimeout);

    // Уровень 1: Warning (default: 75% от SLA)
    await this.scheduleCheck(task.id, 'sla_warning', sla.warningMinutes);

    // Уровень 2: SLA Breach
    await this.scheduleCheck(task.id, 'sla_breach', sla.slaMinutes);
  }

  async handleCheck(taskId: string, checkType: string): Promise<void> {
    const task = await prisma.task.findUnique({ where: { id: taskId } });

    // Задача уже завершена/отменена — ничего не делаем
    if (['COMPLETED', 'CANCELLED'].includes(task.status)) return;

    switch (checkType) {
      case 'acceptance':
        // Задача не принята вовремя
        if (task.status === 'ASSIGNED' || task.status === 'CREATED') {
          // Повторное уведомление исполнителю
          await NotificationService.pushUrgent(task.assigneeId, {
            title: '⚠️ Непринятый запрос',
            body: `${task.title} — ожидает ${this.minutesSince(task.createdAt)} мин`,
          });
          // Алерт супервайзору
          await this.alertSupervisor(task, 'task_not_accepted');
          // Запланировать переназначение через ещё 5 мин
          await this.scheduleCheck(task.id, 'force_reassign', 5);
        }
        break;

      case 'force_reassign':
        if (task.status === 'ASSIGNED' && !task.acceptedAt) {
          await TaskRouter.route(task); // Переназначить другому
          await this.alertShiftManager(task, 'task_force_reassigned');
        }
        break;

      case 'sla_warning':
        if (!['COMPLETED', 'CANCELLED'].includes(task.status)) {
          // Алерт супервайзору и менеджеру
          await this.alertSupervisor(task, 'sla_warning');
          // Обновить ETA гостю
          await ETACalculator.recalculate(task);
        }
        break;

      case 'sla_breach':
        if (!['COMPLETED', 'CANCELLED'].includes(task.status)) {
          // SLA нарушен
          await prisma.task.update({
            where: { id: taskId },
            data: {
              slaBreached: true,
              escalationLevel: Math.min(task.escalationLevel + 1, 3),
            },
          });
          // Сообщение гостю
          await SSEService.sendToGuest(task.guestId, {
            type: 'task_delayed',
            taskId,
            message: getLocalizedMessage('task_delayed_apology', task.guest.language),
          });
          // Алерт GM
          await this.alertGM(task, 'sla_breached');
          // Поднять приоритет
          await prisma.task.update({
            where: { id: taskId },
            data: { priority: 'URGENT' },
          });
          // Логировать для аналитики
          await AnalyticsService.recordSLABreach(task);
        }
        break;
    }
  }
}
```

### 7.3. Ручная эскалация

```typescript
// Сотрудник может эскалировать задачу вручную
// (например: нет ключа от номера, нужно разрешение менеджера, нестандартная ситуация)

async function manualEscalate(
  taskId: string,
  staffId: string,
  reason: string,
  targetRole?: string // 'supervisor' | 'shift_manager' | 'duty_manager'
): Promise<void> {
  const task = await prisma.task.findUnique({ where: { id: taskId } });

  // По умолчанию эскалируем на уровень выше
  const targetLevel = targetRole
    ? ROLE_ESCALATION_LEVEL[targetRole]
    : task.escalationLevel + 1;

  await prisma.task.update({
    where: { id: taskId },
    data: {
      status: 'ESCALATED',
      escalationLevel: targetLevel,
    },
  });

  await TaskNote.create({
    taskId,
    authorId: staffId,
    authorType: 'staff',
    content: `Эскалация: ${reason}`,
    isInternal: true,
  });

  // Уведомить целевую роль
  const targets = await getStaffByRole(task.hotelId, targetRole || ESCALATION_ROLES[targetLevel]);
  await NotificationService.pushToMany(targets, {
    title: `🔺 Эскалация: ${task.title}`,
    body: `Номер ${task.roomNumber} • Причина: ${reason}`,
    data: { taskId, action: 'review_escalation' },
    priority: 'high',
  });
}

### 5.2. Допустимые переходы

```typescript
const VALID_TRANSITIONS: Record<TaskStatus, TaskStatus[]> = {
  CREATED:      ['ASSIGNED', 'CANCELLED', 'ESCALATED'],
  ASSIGNED:     ['ACCEPTED', 'CANCELLED', 'ESCALATED', 'ASSIGNED'], // последнее = переназначение
  ACCEPTED:     ['IN_PROGRESS', 'CANCELLED', 'ESCALATED', 'ASSIGNED'], // ASSIGNED = отклонил
  IN_PROGRESS:  ['COMPLETED', 'ON_HOLD', 'CANCELLED', 'ESCALATED'],
  ON_HOLD:      ['IN_PROGRESS', 'CANCELLED', 'ESCALATED'],
  COMPLETED:    [], // Финальный статус. Только reopening через спец. action.
  CANCELLED:    [], // Финальный статус.
  ESCALATED:    ['ASSIGNED'], // После эскалации — переназначение
};

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  GENERAL_MANAGER
  HEAD_OF_DEPT
  SUPERVISOR
  LINE_STAFF
  RECEPTIONIST
}

enum StaffDepartment {
  HOUSEKEEPING
  MAINTENANCE
  FOOD_AND_BEVERAGE
  FRONT_OFFICE
  SECURITY
  MANAGEMENT
}

enum TaskStatus {
  NEW
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  INSPECTED
  CLOSED
  CANCELLED
  ESCALATED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EntrySource {
  widget
  qr_room
  qr_lobby
  qr_restaurant
  qr_spa
  qr_elevator
  sms_booking
  organic
  direct
}

enum JourneyStage {
  PRE_ARRIVAL
  CHECKED_IN
  IN_STAY
  CHECKOUT
  POST_STAY
  BETWEEN_STAYS
}

enum LateCheckoutStatus {
  PENDING
  APPROVED
  DECLINED
}

enum ServiceSource {
  MANUAL
  POS_SYNC
}

enum OrderType {
  FOOD
  HOUSEKEEPING
  SPA
  TRANSPORT
}

enum OrderStatus {
  PENDING
  SENT_TO_POS
  CONFIRMED
  PREPARING
  READY
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

model GuestAccount {
  id             String      @id @default(uuid())
  email          String?     @unique
  phone          String?     @unique
  firstName      String
  lastName       String?
  phoneVerified  Boolean     @default(false)
  emailVerified  Boolean     @default(false)
  createdVia     EntrySource @default(organic)
  roomieChatId   String?
  expoPushToken  String?
  profile        Json?
  preferences    Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  stays             GuestStay[]
  appOpens          AppOpen[]
  hotelLinks        GuestHotel[]
  orders            Order[]
  serviceRequests   ServiceRequest[]

  @@map("guest_accounts")
}

model Hotel {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  location      String?
  description   String?
  theme         Json?
  accentColor   String?  @default("#1152d4")
  imageUrl      String?
  contactEmail  String?
  contactPhone  String?
  timezone      String   @default("UTC")
  settings      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stays              GuestStay[]
  appOpens           AppOpen[]
  guestLinks         GuestHotel[]
  services           HotelService[]
  posConfig          HotelPOSConfig?
  pmsConfig          HotelPMSConfig?
  smsConfig          HotelSMSConfig?
  smsLogs            SMSLog[]
  qrCodes            QRCode[]
  managerLinks       DashboardManagerHotel[]
  serviceCategories  ServiceCategory[]
  serviceRequests    ServiceRequest[]
  tmsConfig          HotelTMSConfig?
  staffMembers       StaffMember[]
  internalTasks      InternalTask[]
  taskTemplates      TaskTemplate[]
  departments        Department[]
  staffGroups        StaffGroup[]
  rooms              Room[]

  @@map("hotels")
}

model GuestHotel {
  id            String      @id @default(uuid())
  guestId       String
  hotelId       String
  source        EntrySource @default(organic)
  linkedAt      DateTime    @default(now())
  roomNumber    String?
  contextParams Json?

  guest         GuestAccount @relation(fields: [guestId], references: [id])
  hotel         Hotel        @relation(fields: [hotelId], references: [id])

  @@unique([guestId, hotelId])
  @@map("guest_hotels")
}

model GuestStay {
  id                      String       @id @default(uuid())
  guestId                 String
  hotelId                 String
  bookingRef              String?
  stage                   JourneyStage @default(BETWEEN_STAYS)
  roomNumber              String?
  roomType                String?
  checkIn                 DateTime?
  checkOut                DateTime?
  enteredVia              EntrySource?
  pmsData                 Json?
  preCheckinCompleted     Boolean      @default(false)
  preCheckinUrl           String?
  preCheckinExpiresAt     DateTime?
  preCheckinData          Json?
  externalReservationId   String?      @unique
  pmsProvider             String?
  pmsRawData              Json?
  source                  String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  extensionRequestedUntil DateTime?
  extensionStatus         LateCheckoutStatus?

  guest                GuestAccount        @relation(fields: [guestId], references: [id])
  hotel                Hotel               @relation(fields: [hotelId], references: [id])
  stageTransitions     StageTransition[]
  smsLogs              SMSLog[]
  serviceRequests      ServiceRequest[]
  lateCheckoutRequests LateCheckoutRequest[]

  @@map("guest_stays")
}

model AppOpen {
  id                      String      @id @default(uuid())
  guestId                 String?
  hotelId                 String?
  source                  EntrySource
  contextParams           Json?
  deviceInfo              Json?
  resultedInRegistration  Boolean     @default(false)
  createdAt               DateTime    @default(now())

  guest                   GuestAccount? @relation(fields: [guestId], references: [id])
  hotel                   Hotel?        @relation(fields: [hotelId], references: [id])

  @@map("app_opens")
}

// ──── Late Checkout Requests ──────────────────────

model LateCheckoutRequest {
  id            String             @id @default(uuid())
  stayId        String
  requestedTime String             // e.g. "13:00"
  status        LateCheckoutStatus @default(PENDING)
  notes         String?
  taskId        String?            // InternalTask.id created for front office
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  stay          GuestStay          @relation(fields: [stayId], references: [id])

  @@index([stayId])
  @@map("late_checkout_requests")
}

// ──── PMS Config ─────────────────────────────────

model HotelPMSConfig {
  id                  String    @id @default(uuid())
  hotelId             String    @unique
  pmsType             String
  credentials         Json
  pmsHotelId          String?
  syncMode            String    @default("DISABLED")
  lastSyncAt          DateTime?
  isActive            Boolean   @default(false)
  preCheckinUrl       String?
  syncIntervalMinutes Int       @default(15)
  syncEnabled         Boolean   @default(true)
  webhookSecret       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  hotel               Hotel     @relation(fields: [hotelId], references: [id])

  @@map("hotel_pms_configs")
}

// ──── POS Config ─────────────────────────────────

model HotelPOSConfig {
  id            String    @id @default(uuid())
  hotelId       String    @unique
  posType       String
  apiUrl        String
  accessToken   String
  spotId        String?
  syncEnabled   Boolean   @default(false)
  syncInterval  Int       @default(60)
  lastSyncAt    DateTime?
  lastError     String?
  categoryMap   Json?

  hotel         Hotel     @relation(fields: [hotelId], references: [id])

  @@map("hotel_pos_configs")
}

// ──── Hotel Services (Menu) ──────────────────────

model HotelService {
  id            String        @id @default(uuid())
  hotelId       String
  category      String
  name          String
  description   String?
  price         Decimal?
  currency      String        @default("EUR")
  imageUrl      String?
  isAvailable   Boolean       @default(true)
  sortOrder     Int           @default(0)
  cookingTime   Int?

  source        ServiceSource @default(MANUAL)
  posItemId     String?
  posCategory   String?
  posData       Json?
  lastSyncAt    DateTime?

  hotel         Hotel         @relation(fields: [hotelId], references: [id])
  orderItems    OrderItem[]

  @@unique([hotelId, posItemId])
  @@index([hotelId, category, isAvailable])
  @@map("hotel_services")
}

// ──── Orders ─────────────────────────────────────

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique
  guestId             String
  hotelId             String
  type                OrderType
  status              OrderStatus @default(PENDING)
  roomNumber          String?
  specialInstructions String?
  deliveryTime        String?
  subtotal            Decimal     @default(0)
  currency            String      @default("EUR")

  posOrderId          String?
  posStatus           String?
  posTransactionId    String?

  maxCookingTime      Int?
  estimatedAt         DateTime?

  assignedStaffId     String?
  staffNote           String?
  estimatedMinutes    Int?
  priority            TaskPriority @default(NORMAL)
  tmsTaskId           String?

  // Phase 3: Enhanced fields
  escalationLevel     Int          @default(0)
  slaBreached         Boolean      @default(false)
  slaMinutes          Int?
  dueAt               DateTime?
  etaMinutes          Int?
  etaUpdatedAt        DateTime?
  source              String       @default("BUTTON") // BUTTON | CHAT | QR | SYSTEM | POS
  chatMessageId       String?
  rating              Int?
  ratingComment       String?
  ratedAt             DateTime?
  syncStatus          String       @default("NOT_SYNCED")

  confirmedAt         DateTime?
  preparingAt         DateTime?
  readyAt             DateTime?
  inTransitAt         DateTime?
  deliveredAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  guest               GuestAccount @relation(fields: [guestId], references: [id])
  items               OrderItem[]

  @@index([guestId, hotelId])
  @@index([status])
  @@index([posOrderId])
  @@map("orders")
}

model OrderItem {
  id            String       @id @default(uuid())
  orderId       String
  serviceId     String
  quantity      Int          @default(1)
  price         Decimal
  modifiers     Json?
  notes         String?

  order         Order        @relation(fields: [orderId], references: [id])
  service       HotelService @relation(fields: [serviceId], references: [id])

  @@map("order_items")
}

// ──── Stage Transition Log ──────────────────────

model StageTransition {
  id          String    @id @default(uuid())
  guestStayId String
  fromStage   String
  toStage     String
  reason      String
  metadata    Json?
  createdAt   DateTime  @default(now())

  guestStay   GuestStay @relation(fields: [guestStayId], references: [id])

  @@index([guestStayId])
  @@map("stage_transitions")
}

// ──── SMS Config ────────────────────────────────

model HotelSMSConfig {
  id          String   @id @default(uuid())
  hotelId     String   @unique
  provider    String
  credentials Json
  senderName  String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel       Hotel    @relation(fields: [hotelId], references: [id])

  @@map("hotel_sms_configs")
}

// ──── SMS Logs ──────────────────────────────────

model SMSLog {
  id          String    @id @default(uuid())
  hotelId     String
  guestId     String?
  guestStayId String?
  phone       String
  template    String
  provider    String
  status      String    @default("queued")
  externalId  String?
  errorMsg    String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  hotel       Hotel     @relation(fields: [hotelId], references: [id])
  guestStay   GuestStay? @relation(fields: [guestStayId], references: [id])

  @@index([hotelId, createdAt])
  @@index([guestStayId])
  @@map("sms_logs")
}

// ──── QR Codes ──────────────────────────────────

model QRCode {
  id           String   @id @default(uuid())
  hotelId      String
  type         String   @default("in_room")
  label        String
  roomNumber   String?
  deepLink     String
  qrImagePath  String?
  pdfPath      String?
  isActive     Boolean  @default(true)
  scanCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel        Hotel    @relation(fields: [hotelId], references: [id])
  scans        QRScan[]

  @@unique([hotelId, roomNumber])
  @@index([hotelId])
  @@map("qr_codes")
}

model QRScan {
  id        String   @id @default(uuid())
  qrCodeId  String
  guestId   String?
  userAgent String?
  ip        String?
  scannedAt DateTime @default(now())

  qrCode    QRCode   @relation(fields: [qrCodeId], references: [id])

  @@index([qrCodeId, scannedAt])
  @@map("qr_scans")
}

// ──── Dashboard Managers ─────────────────────────

model DashboardManager {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         String   @default("manager")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotels       DashboardManagerHotel[]

  @@map("dashboard_managers")
}

model DashboardManagerHotel {
  id        String @id @default(uuid())
  managerId String
  hotelId   String

  manager   DashboardManager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  hotel     Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([managerId, hotelId])
  @@map("dashboard_manager_hotels")
}

// ──── Service Categories (Task Management) ───────────────────

model ServiceCategory {
  id              String   @id @default(uuid())
  hotelId         String
  name            String
  nameUk          String?
  nameEn          String?
  slug            String
  icon            String?
  description     String?
  descriptionUk   String?
  descriptionEn   String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)

  requiresRoom      Boolean @default(true)
  requiresTimeSlot  Boolean @default(false)
  autoAccept        Boolean @default(false)
  estimatedMinutes  Int?

  // SLA & ETA configuration
  slaMinutes        Int?
  slaWarningMinutes Int?
  defaultEtaMinutes Int?

  // Department link (optional — for task routing)
  defaultDepartmentId String?
  defaultDepartment   Department? @relation("CategoryDepartment", fields: [defaultDepartmentId], references: [id])

  hotel           Hotel           @relation(fields: [hotelId], references: [id])
  items           ServiceItem[]
  requests        ServiceRequest[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([hotelId, slug])
  @@index([hotelId, isActive])
  @@map("service_categories")
}

model ServiceItem {
  id              String   @id @default(uuid())
  categoryId      String
  name            String
  nameUk          String?
  nameEn          String?
  description     String?
  descriptionUk   String?
  descriptionEn   String?
  icon            String?
  price           Float    @default(0)
  currency        String   @default("UAH")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  maxQuantity     Int      @default(10)

  category        ServiceCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  requestItems    ServiceRequestItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoryId, isActive])
  @@map("service_items")
}

// ──── Service Requests (Guest Orders for Hotel Services) ─────

model ServiceRequest {
  id              String   @id @default(uuid())
  hotelId         String
  guestId         String
  guestStayId     String?
  categoryId      String

  roomNumber      String?
  comment         String?
  requestedTime   DateTime?
  scheduledTime   DateTime?

  status          String   @default("pending")
  rejectionReason String?
  completedAt     DateTime?

  totalAmount     Float    @default(0)
  isPaid          Boolean  @default(false)

  externalTaskId  String?
  externalSystem  String?

  assignedStaffId String?
  staffNote       String?
  priority        TaskPriority @default(NORMAL)
  tmsTaskId       String?

  // Phase 3: Enhanced fields
  escalationLevel   Int       @default(0)
  slaBreached       Boolean   @default(false)
  slaMinutes        Int?
  dueAt             DateTime?
  etaMinutes        Int?
  etaUpdatedAt      DateTime?
  startedAt         DateTime?
  source            String    @default("BUTTON") // BUTTON | CHAT | QR | SYSTEM
  chatMessageId     String?
  rating            Int?
  ratingComment     String?
  ratedAt           DateTime?
  syncStatus        String    @default("NOT_SYNCED")
  assigneeGroupId   String?
  acceptedAt        DateTime?

  hotel           Hotel              @relation(fields: [hotelId], references: [id])
  guest           GuestAccount       @relation(fields: [guestId], references: [id])
  guestStay       GuestStay?         @relation(fields: [guestStayId], references: [id])
  category        ServiceCategory    @relation(fields: [categoryId], references: [id])
  items           ServiceRequestItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([hotelId, status])
  @@index([guestId])
  @@index([guestStayId])
  @@index([hotelId, createdAt])
  @@map("service_requests")
}

model ServiceRequestItem {
  id                String   @id @default(uuid())
  serviceRequestId  String
  serviceItemId     String
  quantity          Int      @default(1)
  unitPrice         Float    @default(0)
  totalPrice        Float    @default(0)

  serviceRequest    ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  serviceItem       ServiceItem    @relation(fields: [serviceItemId], references: [id])

  @@index([serviceRequestId])
  @@map("service_request_items")
}

// ──── Staff Members ───────────────────────────────────────────

model StaffMember {
  id            String          @id @default(uuid())
  hotelId       String
  email         String
  phone         String?
  firstName     String
  lastName      String?
  role          StaffRole
  department    StaffDepartment
  passwordHash  String
  pin           String?
  isActive        Boolean         @default(true)
  avatarUrl       String?
  fcmToken        String?
  expoPushToken   String?
  assignedFloor   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  hotel              Hotel            @relation(fields: [hotelId], references: [id])
  shifts             StaffShift[]
  createdTasks       InternalTask[]   @relation("CreatedTasks")
  assignedTasks      InternalTask[]   @relation("AssignedTasks")
  comments           TaskComment[]
  uploads            TaskAttachment[]
  groupMemberships   StaffGroupMember[]
  taskPhotos         TaskPhoto[]
  cleaningAssignments Room[]          @relation("RoomCleaner")
  inspectionAssignments Room[]        @relation("RoomInspector")

  @@unique([hotelId, email])
  @@index([hotelId, isActive])
  @@map("staff_members")
}

model StaffShift {
  id        String      @id @default(uuid())
  staffId   String
  hotelId   String
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  isActive  Boolean     @default(true)

  staff     StaffMember @relation(fields: [staffId], references: [id])

  @@index([hotelId, isActive])
  @@map("staff_shifts")
}

// ──── Departments ─────────────────────────────────────────────

model Department {
  id        String   @id @default(uuid())
  hotelId   String
  slug      String
  names     Json     // { "en": "Housekeeping", "uk": "Господарча служба", "ru": "Хозяйственная служба" }
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  hotel          Hotel          @relation(fields: [hotelId], references: [id])
  staffGroups    StaffGroup[]
  serviceCategories ServiceCategory[] @relation("CategoryDepartment")

  @@unique([hotelId, slug])
  @@map("departments")
}

// ──── Staff Groups ────────────────────────────────────────────

enum GroupType {
  FLOOR
  SHIFT
  SKILL
  CUSTOM
}

enum HousekeepingStatus {
  DIRTY
  CLEANING
  CLEANED
  INSPECTED
  READY
  OUT_OF_ORDER
  DO_NOT_DISTURB
}

enum OccupancyStatus {
  VACANT
  OCCUPIED
  STAYOVER
  CHECKOUT
  CHECKIN
}

model StaffGroup {
  id           String    @id @default(uuid())
  hotelId      String
  name         String
  type         GroupType
  departmentId String
  floors       Int[]
  shiftStart   String?
  shiftEnd     String?
  skills       String[]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  hotel        Hotel       @relation(fields: [hotelId], references: [id])
  department   Department  @relation(fields: [departmentId], references: [id])
  members      StaffGroupMember[]

  @@index([hotelId, departmentId])
  @@map("staff_groups")
}

model StaffGroupMember {
  id       String @id @default(uuid())
  groupId  String
  staffId  String

  group    StaffGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  staff    StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([groupId, staffId])
  @@map("staff_group_members")
}

// ──── Internal Tasks (non-guest) ─────────────────────────────

model InternalTask {
  id            String        @id @default(uuid())
  hotelId       String
  title         String
  description   String?
  department    StaffDepartment
  locationLabel String?
  roomNumber    String?
  priority      TaskPriority  @default(NORMAL)
  status        TaskStatus    @default(NEW)
  createdById   String
  assignedToId  String?
  templateId    String?
  slaMinutes    Int?
  dueAt         DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  closedAt      DateTime?
  holdReason    String?

  // Phase 3: Enhanced fields
  escalationLevel   Int       @default(0)
  slaBreached       Boolean   @default(false)
  etaMinutes        Int?
  etaUpdatedAt      DateTime?
  isBillable        Boolean   @default(false)
  cost              Decimal?
  currency          String?   @default("UAH")
  rating            Int?
  ratingComment     String?
  ratedAt           DateTime?
  source            String    @default("STAFF") // STAFF | BUTTON | CHAT | QR | SYSTEM
  chatMessageId     String?
  externalTmsId     String?
  externalTmsType   String?
  syncStatus        String    @default("NOT_SYNCED") // NOT_SYNCED | SYNCING | SYNCED | SYNC_FAILED
  assigneeGroupId   String?
  acceptedAt        DateTime?
  roomId            String?    // Link to Room for cleaning tasks

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  hotel        Hotel          @relation(fields: [hotelId], references: [id])
  createdBy    StaffMember    @relation("CreatedTasks", fields: [createdById], references: [id])
  assignedTo   StaffMember?   @relation("AssignedTasks", fields: [assignedToId], references: [id])
  template     TaskTemplate?  @relation(fields: [templateId], references: [id])
  checklist    TaskChecklist?
  room         Room?          @relation("RoomCleaningTasks", fields: [roomId], references: [id])

  @@index([hotelId, status])
  @@index([hotelId, department])
  @@index([assignedToId])
  @@index([roomId])
  @@map("internal_tasks")
}

// ──── Rooms ─────────────────────────────────────────────────────
model Room {
  id                  String             @id @default(uuid())
  hotelId             String
  roomNumber          String
  floor               Int
  roomType            String?
  maxOccupancy        Int?
  isActive            Boolean            @default(true)

  housekeepingStatus  HousekeepingStatus @default(READY)
  occupancyStatus     OccupancyStatus    @default(VACANT)

  assignedCleanerId   String?
  assignedInspectorId String?

  lastStatusChangedAt DateTime           @default(now())
  lastCleanedAt       DateTime?
  lastInspectedAt     DateTime?
  estimatedReadyAt    DateTime?

  isRush              Boolean            @default(false)
  dndActive           Boolean            @default(false)
  dndStartedAt        DateTime?
  notes               String?

  pmsRoomId           String?
  lastPmsSyncAt       DateTime?

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  hotel               Hotel              @relation(fields: [hotelId], references: [id])
  assignedCleaner     StaffMember?       @relation("RoomCleaner", fields: [assignedCleanerId], references: [id])
  assignedInspector   StaffMember?       @relation("RoomInspector", fields: [assignedInspectorId], references: [id])
  cleaningTasks       InternalTask[]     @relation("RoomCleaningTasks")
  statusHistory       RoomStatusChange[]

  @@unique([hotelId, roomNumber])
  @@index([hotelId, floor])
  @@index([hotelId, housekeepingStatus])
  @@map("rooms")
}

model RoomStatusChange {
  id               String              @id @default(uuid())
  roomId           String
  fromHousekeeping HousekeepingStatus?
  toHousekeeping   HousekeepingStatus?
  fromOccupancy    OccupancyStatus?
  toOccupancy      OccupancyStatus?
  changedByStaffId String?
  changedBySystem  Boolean             @default(false)
  source           String?
  notes            String?
  createdAt        DateTime            @default(now())

  room             Room                @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@map("room_status_changes")
}

// ──── Task Templates & Checklists ────────────────────────────

model TaskTemplate {
  id              String          @id @default(uuid())
  hotelId         String
  name            String
  department      StaffDepartment
  defaultPriority TaskPriority    @default(NORMAL)
  slaMinutes      Int?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())

  hotel           Hotel           @relation(fields: [hotelId], references: [id])
  checklistItems  ChecklistItem[]
  tasks           InternalTask[]

  @@index([hotelId, isActive])
  @@map("task_templates")
}

model ChecklistItem {
  id          String       @id @default(uuid())
  templateId  String
  text        String
  isRequired  Boolean      @default(true)
  sortOrder   Int          @default(0)

  template    TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("checklist_items")
}

model TaskChecklist {
  id             String       @id @default(uuid())
  taskId         String       @unique
  taskType       String       // INTERNAL | ORDER | SERVICE_REQUEST
  completedItems Json         @default("{}")
  isComplete     Boolean      @default(false)
  updatedAt      DateTime     @updatedAt

  internalTask   InternalTask @relation(fields: [taskId], references: [id])

  @@map("task_checklists")
}

// ──── Task Attachments (photos before/after) ─────────────────

model TaskAttachment {
  id        String      @id @default(uuid())
  taskId    String
  taskType  String      // INTERNAL | ORDER | SERVICE_REQUEST
  staffId   String
  fileUrl   String
  fileType  String      @default("image/jpeg")
  label     String?     // "before" | "after"
  createdAt DateTime    @default(now())

  uploader  StaffMember @relation(fields: [staffId], references: [id])

  @@index([taskId, taskType])
  @@map("task_attachments")
}

// ──── Task Comments ───────────────────────────────────────────

model TaskComment {
  id        String      @id @default(uuid())
  taskId    String
  taskType  String      // INTERNAL | ORDER | SERVICE_REQUEST
  staffId   String
  text      String
  createdAt DateTime    @default(now())

  author    StaffMember @relation(fields: [staffId], references: [id])

  @@index([taskId, taskType])
  @@map("task_comments")
}

// ──── Task Photos ───────────────────────────────────────────

model TaskPhoto {
  id           String   @id @default(uuid())
  taskId       String
  taskType     String   // "INTERNAL" | "ORDER" | "SERVICE_REQUEST"
  url          String
  type         String   @default("issue") // "before" | "after" | "issue"
  uploadedById String
  uploadedAt   DateTime @default(now())
  aiAnalysis   Json?

  uploader     StaffMember @relation(fields: [uploadedById], references: [id])

  @@index([taskId, taskType])
  @@map("task_photos")
}

// ──── Task Notes (internal/guest-visible) ────────────────────

model TaskNote {
  id         String   @id @default(uuid())
  taskId     String
  taskType   String   // "INTERNAL" | "ORDER" | "SERVICE_REQUEST"
  authorId   String
  authorType String   @default("staff") // "staff" | "guest" | "system"
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([taskId, taskType])
  @@map("task_notes")
}

// ──── Task Status Change (Audit Trail) ──────────────────────

model TaskStatusChange {
  id             String   @id @default(uuid())
  taskId         String
  taskType       String   // "INTERNAL" | "ORDER" | "SERVICE_REQUEST"
  fromStatus     String?
  toStatus       String
  changedById    String?
  changedByType  String   @default("system") // "staff" | "guest" | "system" | "external"
  reason         String?
  syncedToExternal Boolean @default(false)
  createdAt      DateTime @default(now())

  @@index([taskId, taskType])
  @@map("task_status_changes")
}

// ──── TMS Configuration ──────────────────────────────────────

model HotelTMSConfig {
  id              String   @id @default(uuid())
  hotelId         String   @unique
  provider        String
  credentials     Json
  enabled         Boolean  @default(false)
  categoryMapping Json     @default("{}")

  // Phase 3+7: Extended config
  mode                String   @default("BUILT_IN") // BUILT_IN | EXTERNAL | HYBRID
  webhookSecret       String?
  outgoingWebhookUrl  String?
  departmentMappings  Json?
  staffMappings       Json?
  hybridCategorySlugs String[]
  pollingEnabled      Boolean  @default(false)
  pollingIntervalMs   Int      @default(30000)
  slaConfig           Json?    // { defaultSlaMinutes, escalationChain: [...] }
  escalationChain     Json?    // [{ level: 1, role: 'SUPERVISOR', timeoutMin: 15 }, ...]

  hotel           Hotel    @relation(fields: [hotelId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("hotel_tms_configs")
}
